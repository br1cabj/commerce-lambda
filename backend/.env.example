# Server port
PORT=3001

# MongoDB connection
MONGODB_URI=mongodb://localhost:27017/ecommerce-platform

# JWT secret
JWT_SECRET=your_super_secure_secret_here

# Cloudinary configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email configuration (Gmail)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Environment
NODE_ENV=development

# Shipping carrier (optional - for local carrier integration)
CARRIER_USER=
CARRIER_PASSWORD=
CARRIER_BASE_URL=
CARRIER_CUSTOMER_ID=
CARRIER_POSTAL_CODE_ORIGIN=

# Payment providers (configured per-tenant in admin panel, but can set defaults here)
MERCADOPAGO_ACCESS_TOKEN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
